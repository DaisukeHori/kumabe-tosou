# サイトの canonical URL。Vercel deploy 後の実 URL に差し替える。
NEXT_PUBLIC_SITE_URL=https://kumabe-tosou.vercel.app

# ---- Supabase (URL/anon key は必須。src/lib/env.ts が起動時に検証する) ----
# Supabase プロジェクトの Settings > API から取得する。
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service_role key。絶対にクライアントに露出させない (src/lib/supabase/service.ts のみで使用)。
# 任意設定 — 未設定時は service role 依存機能 (isAdmin の他者 profile 参照・
# 署名付きアップロード URL 発行・運用スクリプト等) が無効化される (graceful degradation)。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- 通知メール (Resend。Phase 1c〜。未設定時は問い合わせ通知を送信スキップ + KMB-E902 ログ) ----
RESEND_API_KEY=your-resend-api-key

# ---- Webhook / cron 共有シークレット (Phase 1c〜2d。未設定時は該当エンドポイントを無効化) ----
# /api/revalidate (pg_cron からの予約公開 revalidate webhook) のヘッダ検証用。
REVALIDATE_SECRET=change-me-to-a-random-secret
# /api/jobs/publish, /api/jobs/watchdog (pg_cron からの起床 webhook) のヘッダ検証用。
JOBS_SECRET=change-me-to-a-random-secret

# ---- AI スタジオ (Phase 2a〜。設計書 §7)。未設定時は /admin/studio が
# 「API キー未設定」バナーを表示し、実行系ボタンを無効化する (graceful degradation)。 ----
# Anthropic Claude API (claude-opus-4-8)。文字起こし整文・要旨抽出・リサーチ・チャネル別生成。
ANTHROPIC_API_KEY=your-anthropic-api-key
# OpenAI (gpt-4o-transcribe)。音声の文字起こし。
OPENAI_API_KEY=your-openai-api-key
